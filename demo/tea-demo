show_comments() {
  local number="$1"
  cat <<EOF
Issue #$number

## Comments
**@review-bot** wrote on 2026-02-20 10:15:
Nice progress. Please add one screenshot of the new render output.

**@alex** wrote on 2026-02-20 12:02:
Added screenshot and cleaned up the section headers.

**@maria** wrote on 2026-02-21 09:44:
Looks good to me now.
EOF
}

action_ok() {
  exit 0
}

comment_ok() {
  local number="$1"
  shift || true
  local body="${*:-}"
  if [[ -n "$body" ]]; then
    printf 'Comment added to PR #%s\n' "$number"
  fi
  exit 0
}

create_ok() {
  echo "$BASE_URL/pulls/99"
  exit 0
}

main() {
  local cmd="${1:-}"
  [[ $# -gt 0 ]] && shift

  case "$cmd" in
    --version|version)
      show_version
      ;;
    pr)
      local sub="${1:-}"
      [[ $# -gt 0 ]] && shift
      case "$sub" in
        ls)
          list_prs "$@"
          ;;
        checkout|approve|reject|review|close|reopen|merge)
          action_ok
          ;;
        create)
          create_ok
          ;;
        comment)
          comment_ok "$@"
          ;;
        *)
          action_ok
          ;;
      esac
      ;;
    comment)
      comment_ok "$@"
      ;;
    issues)
      local number="${1:-42}"
      [[ $# -gt 0 ]] && shift
      show_comments "$number"
      ;;
    *)
      action_ok
      ;;
  esac
}

main "$@"
